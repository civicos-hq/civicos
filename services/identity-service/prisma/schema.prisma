generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CITIZEN
  REPRESENTATIVE
  GOVERNMENT_ADMIN
  NGO
  MODERATOR
  PLATFORM_ADMIN
}

model User {
  id           String   @id @default(uuid()) // UUIDs — never expose sequential IDs (Playbook: Ch. 3)
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(CITIZEN)
  avatarUrl    String?
  communityId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}
