# ─── Databases ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://civicos:civicos@localhost:5432/civicos"

# ─── Cache ──────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Messaging ──────────────────────────────────────────────────────
NATS_URL="nats://localhost:4222"

# ─── Auth ───────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string-minimum-32-chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Services ───────────────────────────────────────────────────────
IDENTITY_SERVICE_PORT=3001
COMMUNITY_SERVICE_PORT=3002
API_GATEWAY_PORT=3000

# ─── Frontend ───────────────────────────────────────────────────────
VITE_API_URL="http://localhost:3000"

# ─── Email ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="CivicOS <noreply@civicos.app>"

# ─── Storage ────────────────────────────────────────────────────────
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET="civicos-uploads"

# ─── AI ─────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxx"
