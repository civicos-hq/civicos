# ─── Dependencies ────────────────────────────────────────────────────────────
**/node_modules
.pnpm-store

# ─── Build outputs ────────────────────────────────────────────────────────────
**/dist
**/.vite
**/.swc
**/.next
# Docusaurus (apps/docs)
**/.docusaurus
apps/docs/build

# ─── TypeScript ───────────────────────────────────────────────────────────────
**/*.tsbuildinfo

# ─── Testing ──────────────────────────────────────────────────────────────────
**/coverage
**/.jest-cache

# ─── Environment — never commit secrets ───────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ─── Monorepo tooling ─────────────────────────────────────────────────────────
.turbo

# ─── Go ───────────────────────────────────────────────────────────────────────
**/tmp/
**/vendor/
# Compiled service binaries — the entry point is cmd/server, so `go build`
# from the service root drops a `server` executable there.
services/*/server

# ─── Prisma ───────────────────────────────────────────────────────────────────
**/prisma/generated
**/*.db
**/*.sqlite

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─── Uploads / user content ──────────────────────────────────────────────────
# The runtime uploads directory sits at each service's root (created on
# startup, e.g. services/community-service/uploads/). Ignore those but do
# not swallow the source-code package at internal/uploads/.
/uploads/
services/*/uploads/

# ─── Certificates & secrets ──────────────────────────────────────────────────
*.pem
*.key
*.cert
*.p12

# ─── Husky internal (hooks themselves ARE committed, this folder is not) ──────
.husky/_

# ─── OS files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ─── Editor ───────────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
.vscode/launch.json
.claude/
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── Misc ────────────────────────────────────────────────────────────────────
*.local
.cache/
tmp/
temp/
